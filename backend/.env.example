# VibeConnect Backend Environment Configuration

# Port number to run the Express server on (default is 5000)
PORT=5000

# MongoDB Connection String (MongoDB Atlas URI or local MongoDB installation)
MONGO_URI=mongodb://localhost:27017/vibeconnect

# JSON Web Token Secret Key for signing login sessions (change to a secure value in production)
JWT_SECRET=vibeconnect_jwt_secret_key_2026

# Allowed frontend origin(s) for CORS in production.
# You can provide CLIENT_URL, FRONTEND_URL, or CORS_ORIGIN as a single URL or a comma-separated list.
CLIENT_URL=http://localhost:5173
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/vibeconnect?retryWrites=true&w=majority
CLIENT_URL=http://localhost:5173
